def canJump(nums):
    
    max_reach = 0
    
    for i in range(len(nums)):
        
        if i > max_reach:
            return False
        
        max_reach = max(max_reach, i + nums[i])
    
    return True


# Taking input from user
nums = list(map(int, input("Enter array elements separated by space: ").split()))

result = canJump(nums)

print("Can reach last index:", result)

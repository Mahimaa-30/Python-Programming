def reverse(x):
    
    INT_MAX = 2147483647
    INT_MIN = -2147483648
    
    sign = -1 if x < 0 else 1
    x = abs(x)
    
    rev = 0
    
    while x != 0:
        digit = x % 10
        x //= 10
        
        # Check overflow before adding digit
        if rev > (INT_MAX - digit) // 10:
            return 0
        
        rev = rev * 10 + digit
    
    return sign * rev


# User input
x = int(input("Enter an integer: "))
print("Reversed Integer:", reverse(x))
